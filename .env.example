POSTGRES_IMAGE=pgvector/pgvector:0.8.2-pg18
POSTGRES_CONTAINER_NAME=topicos-av2-postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_dev
POSTGRES_TEST_DB=app_test
POSTGRES_PORT=5432
WEB_PORT=8000
WEB_CONTAINER_NAME=topicos-av2-judge-web

# Feature flags.
# AI Assistant ainda precisa de ajustes adicionais de configuracao e testes.
# Mantenha desativado por padrao para ocultar o assistente na Web UI.
ENABLE_AI_ASSISTANT=false

# dev/test write backups only to outputs/backup. prod also updates backup_atividade_2.sql.
APP_ENV=dev
BACKUP_ROOT_FILE=backup_atividade_2.sql
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_dev
EMBEDDING_API_KEY=replace-me

# AV3 candidate execution via --provider remote_http.
# EMBEDDING_API_KEY remains separate for retrieval/embeddings.
FEATHERLESS_URL=https://api.featherless.ai/v1
FEATHERLESS_API=replace-me
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_KEY=replace-me

# Judge provider selection.
JUDGE_PROVIDER=remote_http

# Remote HTTP judge endpoint.
# Use your own Colab, Hugging Face Inference Endpoint, vLLM, llama.cpp,
# LM Studio, Ollama proxy, or other OpenAI-compatible endpoint.
REMOTE_JUDGE_BASE_URL=https://your-remote-endpoint.example.com/v1
REMOTE_JUDGE_API_KEY=replace-me

# Optional endpoint overrides. Configure URL and key together only when each
# judge slot runs on a different provider.
# REMOTE_SECONDARY_JUDGE_BASE_URL=https://judge-2-endpoint.example.com/v1
# REMOTE_SECONDARY_JUDGE_API_KEY=replace-me
# REMOTE_ARBITER_JUDGE_BASE_URL=https://arbiter-endpoint.example.com/v1
# REMOTE_ARBITER_JUDGE_API_KEY=replace-me

# Default execution mode.
# Supported values: single, primary_only, 2plus1
JUDGE_PANEL_MODE=2plus1

# Team judge selection.
# single mode uses judge 1 by default.
REMOTE_JUDGE_MODEL=gpt-oss-120b
REMOTE_SECONDARY_JUDGE_MODEL=llama-3.3-70b-instruct
REMOTE_ARBITER_JUDGE_MODEL=m-prometheus-14b

# Arbitration rule.
JUDGE_ARBITRATION_MIN_DELTA=2
JUDGE_ALWAYS_RUN_ARBITER=false

# Judge API call scheduling.
# sequential is safer for local models with limited VRAM.
# parallel can reduce wall time with remote endpoints that support concurrency.
# Supported values: sequential, parallel
JUDGE_EXECUTION_STRATEGY=sequential

# Incremental execution batch size.
# Each run selects up to this many pending AV1 answers from PostgreSQL.
JUDGE_BATCH_SIZE=10

# Remote generation parameters.
REMOTE_JUDGE_TIMEOUT_SECONDS=180
REMOTE_JUDGE_TEMPERATURE=0.0
REMOTE_JUDGE_MAX_TOKENS=4000
REMOTE_JUDGE_TOP_P=1.0

# OpenAI-compatible mode.
REMOTE_JUDGE_OPENAI_COMPATIBLE=true

# Optional debug/audit. Never store secrets here.
JUDGE_SAVE_RAW_RESPONSE=true
